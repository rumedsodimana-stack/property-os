# Environment Variables Template
# Copy this to .env and fill in your API keys

# AI Provider Configuration
# Choose: 'openai' or 'gemini' or 'anthropic' or 'ollama'
VITE_AI_PROVIDER=anthropic

# OpenAI API Key (if using OpenAI)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (if using Anthropic)
# Get from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key (if using Gemini)
# Get from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (existing)
VITE_FIREBASE_API_KEY=your_firebase_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your_app_id
# Set true only when local Firebase emulators are running on configured ports.
VITE_USE_FIREBASE_EMULATORS=false

# Optional: AI Configuration Overrides
# VITE_AI_MODEL=gpt-4-turbo
# VITE_AI_MAX_TOKENS=4000
# VITE_AI_TEMPERATURE=0.7

# Optional: demo local login users (disabled by default)
# VITE_ENABLE_DEMO_USERS=true
# VITE_DEMO_USER_PIN=1234

# Optional: skip login and go directly to operations app (dev only)
# VITE_SKIP_LOGIN=true

# Optional: deployed app URLs (used by WebsiteLanding CTA routing)
# VITE_MAIN_APP_URL=https://your-main-app.web.app/
# VITE_DEMO_APP_URL=https://your-demo-app.web.app/

# Stripe Payment Processing (PCI-DSS SAQ A)
# Get from: https://dashboard.stripe.com/apikeys
# The publishable key is safe to expose in the browser (cannot charge cards).
# The secret key is set server-side: firebase functions:config:set stripe.secret_key="sk_live_..."
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Optional: function simulation hardening
# SINGULARITY_LOCAL_DEV_KEY=your_internal_dev_key
# SINGULARITY_ALLOW_SIMULATED_PROVIDER_KEYS=false
# SINGULARITY_OTA_DEMO_KEY=your_ota_demo_key
# SINGULARITY_STRIPE_DEMO_KEY=your_stripe_demo_key
# SINGULARITY_WALLET_MOCK_BASE_URL=https://wallet-pass.hotelsingularity.local
#
# Optional: Apple Wallet pass signing for installable .pkpass files
# If omitted, the system generates self-signed mock passes for AirDrop tests.
# SINGULARITY_APPLE_MOCK_PASS_TYPE_ID=pass.com.yourcompany.hotelkey
# SINGULARITY_APPLE_MOCK_TEAM_ID=YOURTEAMID
# SINGULARITY_APPLE_MOCK_ORGANIZATION=Your Hotel Brand
# SINGULARITY_APPLE_PASS_CERT=/absolute/path/pass-cert.pem
# SINGULARITY_APPLE_PASS_KEY=/absolute/path/pass-key.pem
# SINGULARITY_APPLE_WWDR_CERT=/absolute/path/AppleWWDRCAG4.pem
# SINGULARITY_OPENSSL_BIN=/usr/bin/openssl
# SINGULARITY_ZIP_BIN=/usr/bin/zip

# Optional: Rate Limiting
# VITE_AI_REQUESTS_PER_MINUTE=60
# VITE_AI_TOKENS_PER_MINUTE=90000

# Webhook secrets (Integrations Hub) – never commit real values
# VITE_WEBHOOK_SECRET_OPS=whsec_your_ops_secret
# VITE_WEBHOOK_SECRET_CRM=whsec_your_crm_secret

# Seed script (Demo_200Rooms/scripts) – use FIREBASE_* or VITE_FIREBASE_*
# FIREBASE_API_KEY=your_firebase_api_key
# FIREBASE_PROJECT_ID=your_project_id
