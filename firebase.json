{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "main",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/demo",
          "destination": "https://singularity-property-os-7843c.web.app",
          "type": 302
        },
        {
          "source": "/demo/**",
          "destination": "https://singularity-property-os-7843c.web.app",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "website",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/demo",
          "destination": "https://singularity-property-os-7843c.web.app",
          "type": 302
        },
        {
          "source": "/demo/**",
          "destination": "https://singularity-property-os-7843c.web.app",
          "type": 302
        },
        {
          "source": "/app",
          "destination": "https://singularity-property-os.web.app",
          "type": 302
        },
        {
          "source": "/app/**",
          "destination": "https://singularity-property-os.web.app",
          "type": 302
        },
        {
          "source": "/",
          "destination": "/website",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8085
    },
    "hosting": {
      "port": 5005
    },
    "ui": {
      "enabled": false
    },
    "singleProjectMode": true
  }
}
